{
    "name": "Section",
    "description": "A token-based layout section with configurable width, spacing, surface, alignment, and an inner content region.",
    "group": "SFNextToolkit",
    "arch_type": "headless",
    "region_definitions": [
        {
            "id": "content",
            "name": "Content",
            "component_type_exclusions": [
                {
                    "type_id": "SFNextToolkit.accordionItem"
                },
                {
                    "type_id": "SFNextToolkit.categoryCard"
                },
                {
                    "type_id": "SFNextToolkit.megaMenu"
                },
                {
                    "type_id": "SFNextToolkit.megaMenuFeature"
                },
                {
                    "type_id": "SFNextToolkit.megaMenuLink"
                },
                {
                    "type_id": "SFNextToolkit.megaMenuPanel"
                },
                {
                    "type_id": "SFNextToolkit.promoCard"
                },
                {
                    "type_id": "SFNextToolkit.siteTheme"
                },
                {
                    "type_id": "SFNextToolkit.sizeGuide"
                },
                {
                    "type_id": "SFNextToolkit.trustItem"
                },
                {
                    "type_id": "SFNextToolkit.section"
                }
            ]
        }
    ],
    "attribute_definition_groups": [
        {
            "id": "section",
            "name": "Section",
            "description": "A token-based layout section with configurable width, spacing, surface, alignment, and an inner content region.",
            "attribute_definitions": [
                {
                    "id": "anchorId",
                    "name": "Anchor ID",
                    "type": "string",
                    "required": false,
                    "description": "Optional HTML anchor used for links to this section. Do not include the # character."
                },
                {
                    "id": "surface",
                    "name": "Surface",
                    "type": "enum",
                    "required": false,
                    "description": "Theme-token surface and its matching text color.",
                    "values": ["transparent", "background", "muted", "card", "primary", "secondary", "accent"],
                    "default_value": "transparent"
                },
                {
                    "id": "spacing",
                    "name": "Vertical Spacing",
                    "type": "enum",
                    "required": false,
                    "description": "Responsive space above and below the section content.",
                    "values": ["none", "sm", "md", "lg", "xl"],
                    "default_value": "md"
                },
                {
                    "id": "contentWidth",
                    "name": "Content Width",
                    "type": "enum",
                    "required": false,
                    "description": "Maximum width of the inner content region.",
                    "values": ["full", "contained", "narrow"],
                    "default_value": "contained"
                },
                {
                    "id": "alignment",
                    "name": "Text Alignment",
                    "type": "enum",
                    "required": false,
                    "description": "Default text alignment inherited by content in the section.",
                    "values": ["left", "center", "right"],
                    "default_value": "left"
                }
            ]
        }
    ]
}
