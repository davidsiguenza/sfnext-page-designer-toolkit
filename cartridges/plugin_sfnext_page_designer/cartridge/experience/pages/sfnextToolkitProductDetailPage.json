{
    "name": "SFNext Toolkit - Product Detail",
    "description": "Storefront Next product detail template that reuses the standard product experience and adds managed content regions.",
    "arch_type": "headless",
    "region_definitions": [
        {
            "id": "promoContent",
            "name": "Promotional Content",
            "component_type_exclusions": [
                { "type_id": "SFNextToolkit.accordionItem" },
                { "type_id": "SFNextToolkit.categoryCard" },
                { "type_id": "SFNextToolkit.megaMenu" },
                { "type_id": "SFNextToolkit.megaMenuFeature" },
                { "type_id": "SFNextToolkit.megaMenuLink" },
                { "type_id": "SFNextToolkit.megaMenuPanel" },
                { "type_id": "SFNextToolkit.promoCard" },
                { "type_id": "SFNextToolkit.siteTheme" },
                { "type_id": "SFNextToolkit.sizeGuide" },
                { "type_id": "SFNextToolkit.trustItem" }
            ],
            "max_components": 5
        },
        {
            "id": "productTools",
            "name": "Product Tools",
            "component_type_inclusions": [{ "type_id": "SFNextToolkit.sizeGuide" }],
            "max_components": 1
        },
        {
            "id": "engagementContent",
            "name": "Engagement Content",
            "component_type_exclusions": [
                { "type_id": "SFNextToolkit.accordionItem" },
                { "type_id": "SFNextToolkit.categoryCard" },
                { "type_id": "SFNextToolkit.megaMenu" },
                { "type_id": "SFNextToolkit.megaMenuFeature" },
                { "type_id": "SFNextToolkit.megaMenuLink" },
                { "type_id": "SFNextToolkit.megaMenuPanel" },
                { "type_id": "SFNextToolkit.promoCard" },
                { "type_id": "SFNextToolkit.siteTheme" },
                { "type_id": "SFNextToolkit.sizeGuide" },
                { "type_id": "SFNextToolkit.trustItem" }
            ],
            "max_components": 5
        }
    ],
    "supported_aspect_types": ["pdp"],
    "route": "/:siteId/:localeId/product/:productId"
}
